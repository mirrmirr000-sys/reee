-- SBBF CFW Hover v3 - Auto Aim + Auto Click | Balanced Height | Godmode | Auto Restart
-- Optimized for ranged users

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VirtualUser = game:GetService("VirtualUser")

local player = Players.LocalPlayer
local character, humanoid, root

local HOVER_HEIGHT = 75          -- Balanced - should dodge Ruby Drill without being too high
local SMOOTH_SPEED = 13
local enabled = true

local function setupCharacter()
    character = player.Character or player.CharacterAdded:Wait()
    humanoid = character:WaitForChild("Humanoid")
    root = character:WaitForChild("HumanoidRootPart")
    
    -- Strong Godmode
    humanoid.MaxHealth = math.huge
    humanoid.Health = math.huge
    
    humanoid.Died:Connect(function()
        wait(2) -- wait for respawn
        setupCharacter() -- Restart script logic on death
    end)
end

setupCharacter()

print("🛡️ CFW Hover v3 Loaded - Auto Aim + Click | Godmode Active")

local function findCFW()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:FindFirstChild("Humanoid") and obj.Humanoid.Health > 0 then
            local name = obj.Name:lower()
            if name:find("cazar") or name:find("cfw") or name:find("fallen") then
                return obj
            end
        end
    end
    return nil
end

-- Main Loop
local connection
connection = RunService.Heartbeat:Connect(function()
    if not enabled or not root or not humanoid then return end
    
    local boss = findCFW()
    if not boss then return end
    
    local bossPos = boss:GetPivot().Position
    local targetPos = bossPos + Vector3.new(0, HOVER_HEIGHT, 0) 
                     + Vector3.new(math.sin(tick()*0.7)*10, 5, math.cos(tick()*0.7)*10)
    
    local direction = (targetPos - root.Position)
    local distance = direction.Magnitude
    
    if distance > 12 then
        root.Velocity = direction.Unit * SMOOTH_SPEED * math.min(distance / 30, 1.8)
    else
        root.Velocity = Vector3.new(0, 3 + math.sin(tick()*2.5)*2, 0)
    end
    
    -- Strong Auto Aim
    local lookCFrame = CFrame.lookAt(root.Position, bossPos)
    root.CFrame = root.CFrame:Lerp(lookCFrame * CFrame.Angles(0, math.rad(180), 0), 0.3)
    
    -- Auto Click (simulates left click for ranged attacks)
    pcall(function()
        VirtualUser:CaptureController()
        VirtualUser:ClickButton1(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    end)
end)

-- Light + Godmode regen
spawn(function()
    while wait(0.4) do
        if humanoid then
            humanoid.Health = math.huge
        end
    end
end)

print("✅ Hover + Auto Aim + Auto Click Active!")
print("Left Ctrl = Toggle | Left Shift = +Height | Left Alt = -Height")

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.LeftControl then
        enabled = not enabled
        print("Hover " .. (enabled and "ON" or "OFF"))
    elseif input.KeyCode == Enum.KeyCode.LeftShift then
        HOVER_HEIGHT = HOVER_HEIGHT + 10
        print("Height ↑ " .. HOVER_HEIGHT)
    elseif input.KeyCode == Enum.KeyCode.LeftAlt then
        HOVER_HEIGHT = math.max(50, HOVER_HEIGHT - 10)
        print("Height ↓ " .. HOVER_HEIGHT)
    end
end)

-- Full script restart support
player.CharacterAdded:Connect(setupCharacter)
