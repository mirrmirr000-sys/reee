-- SBBF Carnnelio Noble Solo Script - Dodge + Block + Outcry
-- Stay far | Block → Outcry | Low detection

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local root = character:WaitForChild("HumanoidRootPart")

print("🛡️ Carnnelio Noble Solo Script Loaded")

local ENABLED = true
local TARGET_DISTANCE = 55   -- Keep this far (adjust with Shift/Alt)
local lastAction = 0

local function findCarnnelio()
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:FindFirstChild("Humanoid") and obj.Humanoid.Health > 0 then
            local n = obj.Name:lower()
            if n:find("carn") or n:find("carnnelio") or n:find("octavius") then
                return obj
            end
        end
    end
    return nil
end

-- Safe light regen
spawn(function()
    while wait(0.5) do
        if humanoid and humanoid.Health > 0 then
            humanoid.Health = math.min(humanoid.Health + 18, humanoid.MaxHealth)
        end
    end
end)

local connection
connection = RunService.Heartbeat:Connect(function()
    if not ENABLED or not root then return end
    
    local boss = findCarnnelio()
    if not boss then return end
    
    local bossPos = boss:GetPivot().Position
    local myPos = root.Position
    local dist = (bossPos - myPos).Magnitude
    
    -- Gentle face boss
    local lookCFrame = CFrame.lookAt(myPos, bossPos)
    root.CFrame = root.CFrame:Lerp(lookCFrame, 0.15)
    
    -- === DISTANCE CONTROL ===
    if dist < TARGET_DISTANCE - 8 then
        -- Move back safely
        local awayDir = (myPos - bossPos).Unit
        root.Velocity = awayDir * 35 + Vector3.new(0, 8, 0)
    elseif dist > TARGET_DISTANCE + 15 then
        -- Move closer slowly
        local towardDir = (bossPos - myPos).Unit
        root.Velocity = towardDir * 22
    else
        -- Gentle orbit
        root.Velocity = root.Velocity * 0.7
    end
    
    -- === DODGE + BLOCK LOGIC ===
    if tick() - lastAction < 0.7 then return end
    
    -- Auto Block / Parry when close or during combo (Noble parry key is usually F or specific)
    if dist < 70 then
        -- Simulate Block/Parry (change key if your bind is different)
        keypress(0x46)  -- F key (common for parry)
        wait(0.05)
        keyrelease(0x46)
        
        -- After successful block → Crimson Outcry (usually X key)
        wait(0.15)
        keypress(0x58)  -- X key
        wait(0.08)
        keyrelease(0x58)
        
        lastAction = tick()
    end
end)

print("✅ Script Active!")
print("Stay near the boss - it will keep distance, dodge, block, and Outcry after block.")
print("Left Ctrl = Toggle | Left Shift = +Distance | Left Alt = -Distance")

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.LeftControl then
        ENABLED = not ENABLED
        print("Script " .. (ENABLED and "ON" or "OFF"))
    elseif input.KeyCode == Enum.KeyCode.LeftShift then
        TARGET_DISTANCE = TARGET_DISTANCE + 8
        print("Target Distance: " .. TARGET_DISTANCE)
    elseif input.KeyCode == Enum.KeyCode.LeftAlt then
        TARGET_DISTANCE = math.max(35, TARGET_DISTANCE - 8)
        print("Target Distance: " .. TARGET_DISTANCE)
    end
end)

-- Auto restart on death
player.CharacterAdded:Connect(function(newChar)
    wait(1.5)
    character = newChar
    humanoid = newChar:WaitForChild("Humanoid")
    root = newChar:WaitForChild("HumanoidRootPart")
    print("Respawned - Script restarted")
end)
